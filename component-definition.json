{
  "groups": [
    {
      "title": "Default Content",
      "id": "default",
      "components": [
        {
          "title": "Text",
          "id": "text",
          "model": "text",
          "plugins": {
            "da": {
              "name": "text",
              "type": "text"
            }
          }
        },
        {
          "title": "Image",
          "id": "image",
          "model": "image",
          "plugins": {
            "da": {
              "name": "image",
              "type": "image",
              "fields": [
                { "name": "image", "selector": "img[src]" },
                { "name": "imageAlt", "selector": "img[alt]" }
              ]
            }
          }
        }
      ]
    },
    {
      "title": "Sections",
      "id": "sections",
      "components": [
        {
          "title": "Section",
          "id": "section",
          "model": "section",
          "filter": "section",
          "plugins": {
            "da": {
              "unsafeHTML": "<div></div>"
            }
          }
        }
      ]
    },
    {
      "title": "Blocks",
      "id": "blocks",
      "components": [
        {
          "title": "Hero",
          "id": "hero",
          "model": "hero",
          "plugins": {
            "da": {
              "name": "hero",
              "rows": 2,
              "columns": 1,
              "fields": [
                { "name": "image", "selector": "div:nth-child(1)>div>picture>img[src]" },
                { "name": "imageAlt", "selector": "div:nth-child(1)>div>picture>img[alt]" },
                { "name": "content", "selector": "div:nth-child(2)>div" }
              ]
            }
          }
        },
        {
          "title": "Card",
          "id": "card",
          "model": "card",
          "plugins": {
            "da": {
              "name": "card",
              "rows": 1,
              "columns": 1,
              "fields": [
                { "name": "image", "selector": "div>div>picture>img[src]" },
                { "name": "imageAlt", "selector": "div>div>picture>img[alt]" },
                { "name": "content", "selector": "div>div" }
              ]
            }
          }
        },
        {
          "title": "Columns",
          "id": "columns",
          "model": "columns",
          "filter": "columns",
          "plugins": {
            "da": {
              "behaviour": "columns"
            }
          }
        },
        {
          "title": "Columns Row",
          "id": "columns-row",
          "filter": "columns-row",
          "plugins": {
            "da": {
              "behaviour": "columns-row"
            }
          }
        },
        {
          "title": "Columns Cell",
          "id": "columns-cell",
          "plugins": {
            "da": {
              "behaviour": "columns-cell",
              "unsafeHTML": "<div></div>"
            }
          }
        },
        {
          "title": "YouTube",
          "id": "youtube",
          "model": "youtube",
          "plugins": {
            "da": {
              "name": "youtube",
              "rows": 1,
              "columns": 1,
              "fields": [
                { "name": "url", "selector": "div>div>a[href]" }
              ]
            }
          }
        },
        {
          "title": "Advanced Tabs",
          "id": "advanced-tabs",
          "model": "advanced-tabs",
          "plugins": {
            "da": {
              "name": "advanced-tabs",
              "rows": 1,
              "columns": 1,
              "fields": [
                { "name": "tabs", "selector": "div>div>ul" }
              ]
            }
          }
        },
        {
          "title": "Section Metadata",
          "id": "section-metadata",
          "model": "section-metadata",
          "plugins": {
            "da": {
              "name": "section-metadata",
              "type": "key-value-block"
            }
          }
        }
      ]
    }
  ]
}
